# Copy to .env.local and fill in. Only VITE_-prefixed vars reach the browser.

# Supabase (frontend-safe: anon key is RLS-gated)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# YouTube Data API v3 key — create in Google Cloud Console, enable
# "YouTube Data API v3", then restrict the key by HTTP referrer to your domain.
VITE_YOUTUBE_API_KEY=

# Gemini API key for client-side AI analysis (hackathon demo). Exposed in the
# browser bundle — restrict it in Google AI Studio / Cloud. For production this
# call belongs in a backend / Edge Function instead.
VITE_GEMINI_API_KEY=

# --- Server-side only (NEVER prefix with VITE_; belongs to backend/AI service) ---
# GEMINI_API_KEY=
# SUPABASE_SERVICE_ROLE_KEY=
